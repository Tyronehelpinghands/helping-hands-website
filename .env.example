# Supabase (vereist voor login en dashboards)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Alternatief als je publishable key gebruikt:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# NOOIT in frontend of in deze repo:
# SUPABASE_SERVICE_ROLE_KEY=

# HubSpot (alleen server-side, nooit NEXT_PUBLIC_)
# HUBSPOT_ACCESS_TOKEN=pat-eu1-...
# Optioneel: forceer API region (EU tokens worden automatisch herkend)
# HUBSPOT_API_BASE_PATH=https://api-eu1.hubapi.com
