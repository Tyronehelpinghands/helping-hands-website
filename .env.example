# Supabase (vereist voor login en dashboards)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Alternatief als je publishable key gebruikt:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# NOOIT in frontend of in deze repo:
# SUPABASE_SERVICE_ROLE_KEY=

# HubSpot (alleen server-side, nooit NEXT_PUBLIC_)
# HUBSPOT_ACCESS_TOKEN=pat-eu1-...
# Optioneel: forceer API region (EU tokens worden automatisch herkend)
# HUBSPOT_API_BASE_PATH=https://api-eu1.hubapi.com

# Shiftbase (alleen server-side, nooit NEXT_PUBLIC_)
# SHIFTBASE_API_TOKEN=your-api-token
# SHIFTBASE_API_BASE_URL=https://api.shiftbase.com/api

# Moneybird (alleen server-side)
# MONEYBIRD_ACCESS_TOKEN=your-token
# MONEYBIRD_ADMINISTRATION_ID=your-administration-id
# MONEYBIRD_BASE_URL=https://moneybird.com/api/v2
# MONEYBIRD_DEFAULT_TAX_RATE_ID=
# MONEYBIRD_DEFAULT_LEDGER_ACCOUNT_ID=

# Google Maps (alleen server-side, Distance Matrix API)
# GOOGLE_MAPS_API_KEY=your-google-maps-key
